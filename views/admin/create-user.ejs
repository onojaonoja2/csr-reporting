<%- include('../partials/header') %>
<div class="flex">
  <%- include('../partials/sidebar') %>
  <main class="flex-1 p-6">
    <h2 class="text-2xl font-bold text-brand mb-6">Create New User</h2>
    <div class="card max-w-2xl">
      <% if (error) { %>
        <div class="bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-300 p-3 rounded-lg mb-4 text-sm"><%= error %></div>
      <% } %>
      <form action="/admin/users/create" method="POST" class="space-y-4" id="createUserForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium mb-1">Full Name</label>
            <input type="text" name="fullName" required class="form-input">
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Email</label>
            <input type="email" name="email" required class="form-input" placeholder="user@elkris.com">
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Phone Number</label>
            <input type="tel" name="phoneNumber" required pattern="[0-9]{11}" maxlength="11" class="form-input" placeholder="08012345678">
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Password</label>
            <input type="password" name="password" required class="form-input">
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Role</label>
            <select name="role" id="roleSelect" class="form-input">
              <option value="csr">CSR / Stockist</option>
              <option value="supervisor">Supervisor</option>
              <option value="manager">Manager</option>
              <option value="admin">Admin</option>
            </select>
          </div>
        </div>
        <div id="locationSection" class="space-y-4">
          <hr class="border-brand opacity-30">
          <h4 class="font-semibold text-brand">Location & Address</h4>
          <div>
            <label class="block text-sm font-medium mb-1">Address</label>
            <input type="text" name="address" id="addressInput" class="form-input" placeholder="Street address, area...">
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-medium mb-1">Geo-Political Zone</label>
              <select name="zone" id="zoneSelect" class="form-input">
                <option value="">Select Zone</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">State</label>
              <select name="state" id="stateSelect" class="form-input">
                <option value="">Select State</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">LGA</label>
              <select name="lga" id="lgaSelect" class="form-input">
                <option value="">Select LGA</option>
              </select>
            </div>
          </div>
        </div>
        <button type="submit" class="btn-primary">Create User</button>
      </form>
    </div>
  </main>
</div>
<script>
(function() {
  const roleSelect = document.getElementById('roleSelect');
  const locationSection = document.getElementById('locationSection');
  const zoneSel = document.getElementById('zoneSelect');
  const stateSel = document.getElementById('stateSelect');
  const lgaSel = document.getElementById('lgaSelect');

  function toggleLocation() {
    const isCsr = roleSelect.value === 'csr';
    locationSection.style.display = isCsr ? '' : 'none';
    zoneSel.required = isCsr;
    stateSel.required = isCsr;
    lgaSel.required = isCsr;
  }

  roleSelect.addEventListener('change', toggleLocation);
  toggleLocation();

  const zones = ['North Central','North East','North West','South East','South South','South West'];
  zones.forEach(z => { const o = document.createElement('option'); o.value = z; o.textContent = z; zoneSel.appendChild(o); });

  zoneSel.addEventListener('change', async () => {
    stateSel.innerHTML = '<option value="">Select State</option>';
    lgaSel.innerHTML = '<option value="">Select LGA</option>';
    if (!zoneSel.value) return;
    const res = await fetch('/api/states/' + encodeURIComponent(zoneSel.value));
    const states = await res.json();
    states.forEach(s => { const o = document.createElement('option'); o.value = s; o.textContent = s; stateSel.appendChild(o); });
  });

  stateSel.addEventListener('change', async () => {
    lgaSel.innerHTML = '<option value="">Select LGA</option>';
    if (!zoneSel.value || !stateSel.value) return;
    const res = await fetch('/api/lgas/' + encodeURIComponent(zoneSel.value) + '/' + encodeURIComponent(stateSel.value));
    const lgas = await res.json();
    lgas.forEach(l => { const o = document.createElement('option'); o.value = l; o.textContent = l; lgaSel.appendChild(o); });
  });
})();
</script>
<%- include('../partials/footer') %>
