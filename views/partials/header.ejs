<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Elkris CSR Reporting</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
  <script>
    (function() {
      const savedTheme = localStorage.getItem('elkris-theme');
      if (savedTheme === 'dark' || (!savedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    })();
  </script>
</head>
<body class="min-h-screen bg-frame text-primary">
  <header class="sticky top-0 z-30 bg-brand text-white shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <% if (user) { %>
        <button id="menuToggle" onclick="toggleSidebar()" class="lg:hidden p-2 rounded hover:bg-white/20" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <% } %>
        <div class="w-9 h-9 bg-white rounded-lg flex items-center justify-center shrink-0">
          <span class="text-brand font-bold text-lg">E</span>
        </div>
        <div>
          <h1 class="text-lg font-bold leading-tight">Elkris CSR Reporting</h1>
          <p class="text-xs opacity-80 hidden sm:block">Community Sales Representative Interface</p>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <% if (user) { %>
          <span class="text-sm font-medium hidden sm:inline"><%= user.fullName %></span>
          <span class="text-xs bg-white bg-opacity-20 px-2 py-1 rounded-full uppercase tracking-wider"><%= user.role %></span>
          <a href="/profile" class="text-sm hover:underline">Profile</a>
          <a href="/logout" class="text-sm font-semibold px-3 py-1 rounded border border-white text-white hover:bg-white hover:text-[var(--accent)] transition">Logout</a>
        <% } else { %>
          <a href="/" class="text-sm font-medium hover:underline">Login</a>
        <% } %>
        <button onclick="toggleSystemTheme()" class="w-9 h-9 rounded-full bg-white bg-opacity-20 flex items-center justify-center hover:bg-opacity-30 transition" title="Toggle Theme">
          <svg id="themeIconSun" class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          <svg id="themeIconMoon" class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        </button>
      </div>
    </div>
  </header>
  <script src="/js/themeEngine.js"></script>
  <% if (typeof success !== 'undefined' && success) { %>
  <div id="toast-success" class="fixed top-4 right-4 z-50 bg-green-600 text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-2 text-sm font-medium animate-slide-in">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
    <span><%= success %></span>
    <button onclick="this.parentElement.remove()" class="ml-2 opacity-70 hover:opacity-100">&times;</button>
  </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
  <div id="toast-error" class="fixed top-4 right-4 z-50 bg-red-600 text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-2 text-sm font-medium animate-slide-in">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <span><%= error %></span>
    <button onclick="this.parentElement.remove()" class="ml-2 opacity-70 hover:opacity-100">&times;</button>
  </div>
  <% } %>
  <script>
    document.querySelectorAll('[id^="toast-"]').forEach(t => { setTimeout(() => { t.style.transition = 'opacity 0.5s'; t.style.opacity = '0'; setTimeout(() => t.remove(), 500); }, 5000); });
  </script>
