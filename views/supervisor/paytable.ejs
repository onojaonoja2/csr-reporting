<%- include('../partials/header') %>
<div class="flex">
  <%- include('../partials/sidebar') %>
  <main class="flex-1 p-6">
    <h2 class="text-2xl font-bold text-brand mb-6">Pay Table - <%= currentMonth %></h2>
    <div class="flex justify-between items-center mb-4">
      <p class="text-sm text-secondary">Pay = (Sales / Target) x Salary</p>
      <a href="/supervisor/paytable/export" class="btn-primary text-sm">Export to Excel</a>
    </div>
    <div class="card overflow-x-auto">
      <table>
        <thead>
          <tr class="bg-brand text-white">
            <th>CSR Name</th>
            <th>Phone</th>
            <th>State</th>
            <th>Tier</th>
            <th>Target (&#8358;)</th>
            <th>Salary (&#8358;)</th>
            <th>Present</th>
            <th>Units</th>
            <th>Sales (&#8358;)</th>
            <th>% Target</th>
            <th>Earned (&#8358;)</th>
          </tr>
        </thead>
        <tbody>
          <% payouts.forEach(p => { %>
          <tr class="hover:bg-surface">
            <td class="font-medium"><%= p.fullName %></td>
            <td><%= p.phoneNumber || '' %></td>
            <td><%= p.state || '' %></td>
            <td><span class="text-xs px-2 py-1 rounded bg-blue-100 text-blue-700"><%= p.tierName %></span></td>
            <td><%= p.target.toLocaleString() %></td>
            <td><%= p.baseSalary.toLocaleString() %></td>
            <td><%= p.presentDays %></td>
            <td><%= p.totalUnits %></td>
            <td class="font-semibold"><%= p.totalSales.toLocaleString() %></td>
            <td>
              <span class="font-bold <%= p.percentTarget >= 100 ? 'text-green-600' : p.percentTarget >= 50 ? 'text-yellow-600' : 'text-red-600' %>"><%= p.percentTarget %>%</span>
              <div class="w-16 bg-gray-200 rounded-full h-1.5 inline-block ml-2">
                <div class="h-1.5 rounded-full <%= p.percentTarget >= 100 ? 'bg-green-500' : p.percentTarget >= 50 ? 'bg-yellow-500' : 'bg-red-500' %>" style="width: <%= Math.min(p.percentTarget, 100) %>%"></div>
              </div>
            </td>
            <td class="font-bold text-brand">&#8358;<%= p.earnedPay.toLocaleString() %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
