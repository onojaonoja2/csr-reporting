<%- include('../partials/header') %>
<div class="flex">
  <%- include('../partials/sidebar') %>
  <main class="flex-1 p-6">
    <h2 class="text-2xl font-bold text-brand mb-6">Sales Dashboard</h2>
    <% if (success) { %>
      <div class="bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-300 p-3 rounded-lg mb-4 text-sm"><%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-300 p-3 rounded-lg mb-4 text-sm"><%= error %></div>
    <% } %>

    <div class="flex justify-between items-center mb-6">
      <h3 class="text-lg font-semibold"><%= today %></h3>
      <div class="flex gap-2">
        <% if (!currentMonthArchived) { %>
        <form action="/supervisor/month/end" method="POST" class="confirm-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="button" class="bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium py-2 px-4 rounded-lg confirm-btn" data-msg="Archive the current month? No more sales entries can be logged for this month.">End Month</button>
        </form>
        <% } else { %>
        <form action="/supervisor/month/open" method="POST" class="confirm-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="button" class="bg-teal-600 hover:bg-teal-700 text-white text-sm font-medium py-2 px-4 rounded-lg confirm-btn" data-msg="Reopen the current month? Sales entries can be logged again.">Open Month</button>
        </form>
        <% } %>
        <% if (!dayClosed) { %>
        <form action="/supervisor/day/close" method="POST" class="confirm-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="date" value="<%= today %>">
          <button type="button" class="bg-red-600 hover:bg-red-700 text-white text-sm font-medium py-2 px-4 rounded-lg confirm-btn" data-msg="Close day for all CSRs? CSRs without entries will be marked absent.">Close Day</button>
        </form>
        <% } else { %>
        <form action="/supervisor/day/reopen" method="POST" class="confirm-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="date" value="<%= today %>">
          <button type="button" class="bg-yellow-500 hover:bg-yellow-600 text-white text-sm font-medium py-2 px-4 rounded-lg confirm-btn" data-msg="Reopen the day? CSRs will be able to log sales again.">Reopen Day</button>
        </form>
        <% } %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
      <div class="card">
        <h3 class="font-semibold text-brand mb-4">Log Daily Sales</h3>
        <% if (dayClosed) { %>
          <div class="bg-yellow-50 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 p-3 rounded-lg text-sm mb-4">Day is closed. No further entries can be logged.</div>
        <% } %>
        <form action="/supervisor/sales/log" method="POST" class="space-y-4">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div>
            <label class="block text-sm font-medium mb-1">CSR / Stockist</label>
            <select name="csrId" class="form-input" required id="csrSelect" <%= dayClosed ? 'disabled' : '' %>>
              <option value="">Select CSR</option>
              <% csrs.forEach(c => { %>
                <option value="<%= c.id %>"><%= c.fullName %> (<%= c.phoneNumber || 'N/A' %>)</option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Date</label>
            <input type="date" name="date" class="form-input" required value="<%= today %>" <%= dayClosed ? 'disabled' : '' %>>
          </div>
          <div class="flex items-center gap-2 mb-2">
            <input type="checkbox" name="isPresent" id="isPresent" class="w-4 h-4" checked <%= dayClosed ? 'disabled' : '' %>>
            <label for="isPresent" class="text-sm font-medium">CSR Present Today</label>
          </div>
          <div class="border rounded-lg p-3">
            <div class="flex justify-between items-center mb-2">
              <label class="text-sm font-medium">Products Sold</label>
              <button type="button" onclick="addProductRow()" class="text-xs text-blue-600 hover:underline" <%= dayClosed ? 'disabled' : '' %>>+ Add Product</button>
            </div>
            <div id="productRows" class="space-y-2">
              <div class="flex gap-2 items-end product-row">
                <select name="productIds" class="form-input text-sm flex-1 product-select" required <%= dayClosed ? 'disabled' : '' %>>
                  <option value="">Select Product</option>
                  <% products.forEach(p => { %>
                    <option value="<%= p.id %>"><%= p.name %> (<%= p.grammage %>)</option>
                  <% }) %>
                </select>
                <input type="number" name="quantities" min="1" class="form-input text-sm w-20 qty-input" placeholder="Qty" required <%= dayClosed ? 'disabled' : '' %>>
                <input type="number" name="unitPrices" min="0" class="form-input text-sm w-28 price-input" placeholder="Unit Price" required <%= dayClosed ? 'disabled' : '' %>>
                <input type="text" class="form-input text-sm w-28 value-display" readonly placeholder="Value">
                <button type="button" onclick="removeProductRow(this)" class="text-red-500 hover:text-red-700 text-sm px-1">&times;</button>
              </div>
            </div>
          </div>
          <button type="submit" class="btn-primary" <%= dayClosed ? 'disabled' : '' %>>Log Entry</button>
        </form>
      </div>
      <div class="card">
        <h3 class="font-semibold text-brand mb-4">Today's Entries</h3>
        <div class="max-h-80 overflow-y-auto">
          <table>
            <thead>
              <tr class="text-xs text-secondary border-b">
                <th>CSR</th>
                <th>Phone</th>
                <th>State</th>
                <th>Present</th>
              </tr>
            </thead>
            <tbody>
              <% csrData.forEach(c => { %>
              <tr class="text-sm">
                <td class="font-medium"><%= c.fullName %></td>
                <td><%= c.phoneNumber || 'N/A' %></td>
                <td><%= c.state || 'N/A' %></td>
                <td>
                  <% if (c.isPresent) { %>
                    <span class="text-green-600">Yes</span>
                    <% if (c.todayItems.length > 0) { %>
                      <div class="text-xs text-secondary mt-1">
                        <% c.todayItems.forEach(item => { %>
                          <div><%= item.productName %> (<%= item.productGrammage %>): <%= item.quantity %> x &#8358;<%= item.unitPrice.toLocaleString() %> = &#8358;<%= item.salesValue.toLocaleString() %></div>
                        <% }) %>
                        <div class="font-semibold">Total: &#8358;<%= c.todayValue.toLocaleString() %></div>
                      </div>
                    <% } %>
                  <% } else { %>
                    <span class="text-red-600">No</span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <h3 class="text-lg font-semibold mb-4">CSR Overview</h3>

    <div class="card mb-4">
      <div class="flex flex-wrap gap-3 items-end">
        <div class="flex-1 min-w-[200px]">
          <label class="block text-xs font-medium mb-1">Search</label>
          <input type="text" id="filterName" class="form-input text-sm" placeholder="Name, phone, or state..." oninput="filterCsrTable()">
        </div>
        <div>
          <label class="block text-xs font-medium mb-1">State</label>
          <select id="filterState" class="form-input text-sm" onchange="filterCsrTable()">
            <option value="">All States</option>
            <% [...new Set(csrData.map(c => c.state).filter(Boolean))].sort().forEach(s => { %>
              <option value="<%= s %>"><%= s %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium mb-1">Tier</label>
          <select id="filterTier" class="form-input text-sm" onchange="filterCsrTable()">
            <option value="">All Tiers</option>
            <% [...new Set(csrData.map(c => c.tierName).filter(Boolean))].sort().forEach(t => { %>
              <option value="<%= t %>"><%= t %></option>
            <% }) %>
          </select>
        </div>
        <div class="text-xs text-secondary py-2" id="csrCount"></div>
      </div>
    </div>

    <form action="/supervisor/payment/bulk" method="POST" id="bulkPayDashForm2">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="month" value="<%= today.substring(0, 7) %>">
      <div class="card overflow-x-auto mb-4">
        <table class="csr-table">
          <thead>
            <tr class="text-xs text-secondary border-b">
              <th class="w-10"><input type="checkbox" id="selectAllCsr" onchange="toggleAllChecks()"></th>
              <th>CSR Name</th>
              <th>Phone</th>
              <th>State</th>
              <th>Tier</th>
              <th>Target (&#8358;)</th>
              <th>Sales (&#8358;)</th>
              <th>%</th>
              <th>Today</th>
              <th>Pay</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="csrTableBody">
            <% csrData.forEach(c => { %>
            <tr class="text-sm csr-row" data-name="<%= (c.fullName || '').toLowerCase() %>" data-phone="<%= (c.phoneNumber || '').toLowerCase() %>" data-state="<%= (c.state || '').toLowerCase() %>" data-tier="<%= (c.tierName || '').toLowerCase() %>">
              <td>
                <% if (!c.isPaid) { %>
                  <input type="checkbox" name="csrIds" value="<%= c.id %>" class="csr-check">
                <% } %>
              </td>
              <td class="font-medium"><%= c.fullName %></td>
              <td><%= c.phoneNumber || 'N/A' %></td>
              <td><%= c.state || 'N/A' %></td>
              <td><span class="text-xs px-2 py-1 rounded bg-blue-100 text-blue-700"><%= c.tierName %></span></td>
              <td class="font-medium">&#8358;<%= c.target.toLocaleString() %></td>
              <td class="font-medium">&#8358;<%= c.monthlySales.toLocaleString() %></td>
              <td>
                <span class="font-bold <%= c.percentTarget >= 100 ? 'text-green-600' : c.percentTarget >= 50 ? 'text-yellow-600' : 'text-red-600' %>"><%= c.percentTarget %>%</span>
              </td>
              <td><%= c.isPresent ? 'Present' : 'Not Logged' %></td>
              <td>
                <% if (c.isPaid) { %>
                  <span class="text-green-600 font-semibold">Paid</span>
                <% } else { %>
                  <form action="/supervisor/payment/confirm/<%= c.id %>" method="POST" class="inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="month" value="<%= today.substring(0, 7) %>">
                    <button type="submit" class="text-green-600 hover:underline text-xs" onclick="return confirm('Confirm payment for <%= c.fullName %>?')">Pay</button>
                  </form>
                <% } %>
              </td>
              <td>
                <form action="/supervisor/csr/remove/<%= c.id %>" method="POST" class="inline">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="text-red-500 text-xs hover:underline" onclick="return confirm('Remove <%= c.fullName %>?')">Remove</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <div class="flex items-center justify-between mb-6">
        <div class="flex gap-2 items-center">
          <span class="text-xs text-secondary">Rows per page:</span>
          <select id="perPage" class="form-input text-sm w-16" onchange="paginateCsrTable()">
            <option value="10">10</option>
            <option value="20">20</option>
            <option value="50">50</option>
          </select>
        </div>
        <div class="flex gap-2 items-center">
          <button type="button" class="px-3 py-1 text-sm border rounded hover:bg-surface" onclick="prevPage()">&larr;</button>
          <span id="pageInfo" class="text-sm text-secondary"></span>
          <button type="button" class="px-3 py-1 text-sm border rounded hover:bg-surface" onclick="nextPage()">&rarr;</button>
        </div>
        <button type="button" onclick="document.getElementById('bulkPayDashForm2').submit()" class="bg-green-600 hover:bg-green-700 text-white text-sm font-medium py-2 px-4 rounded-lg">Pay Selected</button>
      </div>
    </form>
  </main>
</div>
<script>
let rowIndex = 1;
function addProductRow() {
  const products = `<%- products.map(p => '<option value="'+p.id+'">'+p.name+' ('+p.grammage+')</option>').join('') %>`;
  const html = '<div class="flex gap-2 items-end product-row"><select name="productIds" class="form-input text-sm flex-1 product-select" required><option value="">Select Product</option>' + products + '</select><input type="number" name="quantities" min="1" class="form-input text-sm w-20 qty-input" placeholder="Qty" required><input type="number" name="unitPrices" min="0" class="form-input text-sm w-28 price-input" placeholder="Unit Price" required><input type="text" class="form-input text-sm w-28 value-display" readonly placeholder="Value"><button type="button" onclick="removeProductRow(this)" class="text-red-500 hover:text-red-700 text-sm px-1">&times;</button></div>';
  document.getElementById('productRows').insertAdjacentHTML('beforeend', html);
  bindCalcEvents(document.querySelector('.product-row:last-child'));
}
function removeProductRow(btn) {
  const rows = document.querySelectorAll('.product-row');
  if (rows.length > 1) btn.closest('.product-row').remove();
}
function calcValue(row) {
  const qty = parseInt(row.querySelector('.qty-input').value) || 0;
  const price = parseInt(row.querySelector('.price-input').value) || 0;
  row.querySelector('.value-display').value = qty * price > 0 ? '\u20A6' + (qty * price).toLocaleString() : '';
}
function bindCalcEvents(row) {
  row.querySelector('.qty-input').addEventListener('input', function() { calcValue(row); });
  row.querySelector('.price-input').addEventListener('input', function() { calcValue(row); });
}
document.querySelectorAll('.product-row').forEach(bindCalcEvents);

// CSR Table filter + pagination
let currentPage = 1;
function filterCsrTable() {
  currentPage = 1;
  paginateCsrTable();
}
function getFilteredRows() {
  const query = document.getElementById('filterName').value.toLowerCase().trim();
  const state = document.getElementById('filterState').value.toLowerCase();
  const tier = document.getElementById('filterTier').value.toLowerCase();
  return Array.from(document.querySelectorAll('.csr-row')).filter(row => {
    const name = row.dataset.name;
    const phone = row.dataset.phone;
    const stateVal = row.dataset.state;
    const tierVal = row.dataset.tier;
    if (state && stateVal !== state) return false;
    if (tier && tierVal !== tier) return false;
    if (query && !name.includes(query) && !phone.includes(query) && !stateVal.includes(query)) return false;
    return true;
  });
}
function paginateCsrTable() {
  const rows = getFilteredRows();
  const perPage = parseInt(document.getElementById('perPage').value);
  const total = rows.length;
  const totalPages = Math.max(1, Math.ceil(total / perPage));
  if (currentPage > totalPages) currentPage = totalPages;
  const start = (currentPage - 1) * perPage;
  const end = start + perPage;
  document.querySelectorAll('.csr-row').forEach(r => r.style.display = 'none');
  rows.slice(start, end).forEach(r => r.style.display = '');
  document.getElementById('pageInfo').textContent = `${currentPage} / ${totalPages}`;
  document.getElementById('csrCount').textContent = `${total} CSR${total !== 1 ? 's' : ''}`;
}
function prevPage() {
  const perPage = parseInt(document.getElementById('perPage').value);
  const total = getFilteredRows().length;
  if (currentPage > 1) { currentPage--; paginateCsrTable(); }
}
function nextPage() {
  const perPage = parseInt(document.getElementById('perPage').value);
  const total = getFilteredRows().length;
  const totalPages = Math.max(1, Math.ceil(total / perPage));
  if (currentPage < totalPages) { currentPage++; paginateCsrTable(); }
}
function toggleAllChecks() {
  const checked = document.getElementById('selectAllCsr').checked;
  document.querySelectorAll('.csr-check').forEach(cb => cb.checked = checked);
}
paginateCsrTable();
</script>
<%- include('../partials/footer') %>