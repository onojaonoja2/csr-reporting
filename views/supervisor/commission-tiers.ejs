<%- include('../partials/header') %>
<div class="flex">
  <%- include('../partials/sidebar') %>
  <main class="flex-1 p-6">
    <h2 class="text-2xl font-bold text-brand mb-6">Commission Tiers</h2>
    <% if (success) { %>
      <div class="bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-300 p-3 rounded-lg mb-4 text-sm"><%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-300 p-3 rounded-lg mb-4 text-sm"><%= error %></div>
    <% } %>
    <p class="text-sm text-secondary mb-6">Define volume-based commission rates for each CSR. Tiers reset monthly. Leave maxUnits empty for the highest tier.</p>

    <% csrs.forEach(c => { %>
      <% const csrTiers = tiers[c.id] || []; %>
      <div class="card mb-6">
        <h3 class="font-semibold text-brand mb-4"><%= c.fullName %> (<%= c.zone || 'N/A' %>)</h3>
        <form action="/supervisor/commission-tiers/<%= c.id %>" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <table class="mb-4">
            <thead>
              <tr class="text-xs text-secondary border-b">
                <th>Min Units</th>
                <th>Max Units</th>
                <th>Rate per Unit (&#8358;)</th>
              </tr>
            </thead>
            <tbody id="tiers-<%= c.id %>">
              <% if (csrTiers.length === 0) { %>
                <tr>
                  <td><input type="number" name="minUnits" min="1" class="form-input w-24" placeholder="1" required></td>
                  <td><input type="number" name="maxUnits" min="1" class="form-input w-24" placeholder="Leave empty for max"></td>
                  <td><input type="number" name="ratePerUnit" min="0" class="form-input w-24" placeholder="30" required></td>
                </tr>
                <tr>
                  <td><input type="number" name="minUnits" min="1" class="form-input w-24" placeholder="51"></td>
                  <td><input type="number" name="maxUnits" min="1" class="form-input w-24" placeholder="100"></td>
                  <td><input type="number" name="ratePerUnit" min="0" class="form-input w-24" placeholder="50"></td>
                </tr>
                <tr>
                  <td><input type="number" name="minUnits" min="1" class="form-input w-24" placeholder="101"></td>
                  <td><input type="number" name="maxUnits" min="1" class="form-input w-24" placeholder=""></td>
                  <td><input type="number" name="ratePerUnit" min="0" class="form-input w-24" placeholder="80"></td>
                </tr>
              <% } else { %>
                <% csrTiers.forEach(t => { %>
                <tr>
                  <td><input type="number" name="minUnits" value="<%= t.minUnits %>" min="1" class="form-input w-24" required></td>
                  <td><input type="number" name="maxUnits" value="<%= t.maxUnits || '' %>" min="1" class="form-input w-24" placeholder="Leave empty for max"></td>
                  <td><input type="number" name="ratePerUnit" value="<%= t.ratePerUnit %>" min="0" class="form-input w-24" required></td>
                </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
          <button type="submit" class="btn-primary text-sm">Save Tiers</button>
        </form>
      </div>
    <% }) %>
  </main>
</div>
<%- include('../partials/footer') %>
