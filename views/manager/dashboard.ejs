<%- include('../partials/header') %>
<div class="flex">
  <%- include('../partials/sidebar') %>
  <main class="flex-1 p-6">
    <h2 class="text-2xl font-bold text-brand mb-6">Remuneration Matrix - <%= currentMonth %></h2>
    <form action="/manager/payment/bulk" method="POST" id="bulkPayDashForm">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="month" value="<%= currentMonth %>">
      <div class="flex justify-between items-center mb-4">
        <div>
          <button type="submit" class="bg-green-600 hover:bg-green-700 text-white text-sm font-medium py-2 px-4 rounded-lg" onclick="return confirm('Pay all selected CSRs for <%= currentMonth %>?')">Pay Selected</button>
        </div>
        <label class="text-sm"><input type="checkbox" id="selectAll" class="mr-1"> Select All</label>
      </div>
      <div class="card overflow-x-auto">
        <table>
          <thead>
            <tr class="bg-brand text-white">
              <th><input type="checkbox" id="selectAllHead"></th>
              <th>CSR Name</th>
              <th>Phone</th>
              <th>State</th>
              <th>Tier</th>
              <th>Target (&#8358;)</th>
              <th>Salary (&#8358;)</th>
              <th>Present</th>
              <th>Units</th>
              <th>Sales (&#8358;)</th>
              <th>% Target</th>
              <th>Earned (&#8358;)</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% payouts.forEach(p => { %>
            <tr class="hover:bg-surface">
              <td>
                <% if (!p.isPaid) { %>
                  <input type="checkbox" name="csrIds" value="<%= p.id %>" class="csr-check">
                <% } %>
              </td>
              <td class="font-medium"><%= p.fullName %></td>
              <td><%= p.phoneNumber || '' %></td>
              <td><%= p.state || '' %></td>
              <td><span class="text-xs px-2 py-1 rounded bg-blue-100 text-blue-700"><%= p.tierName %></span></td>
              <td><%= p.target.toLocaleString() %></td>
              <td><%= p.baseSalary.toLocaleString() %></td>
              <td><%= p.presentDays %></td>
              <td><%= p.totalUnits %></td>
              <td class="font-semibold"><%= p.totalSales.toLocaleString() %></td>
              <td>
                <span class="font-bold <%= p.percentTarget >= 100 ? 'text-green-600' : p.percentTarget >= 50 ? 'text-yellow-600' : 'text-red-600' %>"><%= p.percentTarget %>%</span>
              </td>
              <td class="font-bold text-brand">&#8358;<%= p.earnedPay.toLocaleString() %></td>
              <td>
                <% if (p.isPaid) { %>
                  <span class="text-xs px-2 py-1 rounded bg-green-100 text-green-700">Paid</span>
                <% } else { %>
                  <span class="text-xs px-2 py-1 rounded bg-yellow-100 text-yellow-700">Unpaid</span>
                <% } %>
              </td>
              <td>
                <form action="/manager/csr/remove/<%= p.id %>" method="POST" class="inline confirm-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="button" class="text-red-500 text-xs hover:underline confirm-btn" data-msg="Remove <%= p.fullName %>? They will be offboarded.">Remove</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </form>
  </main>
</div>
<script>
document.getElementById('selectAll').addEventListener('change', function() {
  document.querySelectorAll('.csr-check').forEach(c => { c.checked = this.checked; });
});
document.getElementById('selectAllHead').addEventListener('change', function() {
  document.querySelectorAll('.csr-check').forEach(c => { c.checked = this.checked; });
  document.getElementById('selectAll').checked = this.checked;
});
</script>
  </main>
</div>
<%- include('../partials/footer') %>
