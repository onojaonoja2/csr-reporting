<%- include('../partials/header') %>
<div class="flex">
  <%- include('../partials/sidebar') %>
  <main class="flex-1 p-6">
    <h2 class="text-2xl font-bold text-brand mb-6">Weekly View</h2>
    <div class="card mb-6">
      <form action="/manager/weekly" method="GET" class="flex gap-4 items-end">
        <div>
          <label class="block text-sm font-medium mb-1">Week Starting (Monday)</label>
          <input type="date" name="start" class="form-input" value="<%= weekStart %>">
        </div>
        <button type="submit" class="btn-primary">View</button>
      </form>
      <p class="text-sm text-secondary mt-2"><%= weekStart %> to <%= weekEnd %></p>
    </div>
    <div class="card overflow-x-auto">
      <table>
        <thead>
          <tr class="bg-brand text-white">
            <th>CSR Name</th>
            <th>Phone</th>
            <th>State</th>
            <th>Tier</th>
            <th>Days Present</th>
            <th>Total Units</th>
            <th>Total Sales (&#8358;)</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% weeklyData.forEach(w => { %>
          <tr class="hover:bg-surface">
            <td class="font-medium"><%= w.fullName %></td>
            <td><%= w.phoneNumber || 'N/A' %></td>
            <td><%= w.state || 'N/A' %></td>
            <td><span class="text-xs px-2 py-1 rounded bg-blue-100 text-blue-700"><%= w.tierName %></span></td>
            <td><%= w.presentDays %></td>
            <td><%= w.totalUnits %></td>
            <td class="font-semibold">&#8358;<%= w.totalValue.toLocaleString() %></td>
            <td>
              <form action="/manager/csr/remove/<%= w.id %>" method="POST" class="inline confirm-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="button" class="text-red-500 text-xs hover:underline confirm-btn" data-msg="Remove <%= w.fullName %>?">Remove</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
